# ============================================================
#  Society Gym — single .env file for everything
#  Copy this file:  cp .env.example .env
#  Then fill in your real values below
#  NEVER commit .env to git (it's already in .gitignore)
# ============================================================


# ── BACKEND VARIABLES ────────────────────────────────────────
# These are read by the Node.js backend container

# Supabase — supabase.com > your project > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT secret — must be long and random, never share this
# Generate one by running:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Firebase — used by backend to send push notifications
# Firebase console > Project settings > Service accounts > Generate new private key
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Society gym UPI details
SOCIETY_UPI_ID=societygym@jupiter
SOCIETY_NAME=Society Gym
GYM_FEE_AMOUNT=500

# Frontend URL — used by backend for CORS (your Render frontend URL in production)
FRONTEND_URL=http://localhost:5173


# ── FRONTEND VARIABLES ───────────────────────────────────────
# These are passed to the React/Vite frontend at build time
# MUST be prefixed with VITE_ — Vite ignores anything else

# Backend API URL
# In development this stays as localhost
# On Render, change to your actual backend URL e.g. https://society-gym-api.onrender.com
VITE_API_URL=http://localhost:4000

# Firebase — used by frontend to receive push notifications
# Firebase console > Project settings > Your apps > Web app > Config
VITE_FCM_API_KEY=your-firebase-api-key
VITE_FCM_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FCM_PROJECT_ID=your-firebase-project-id
VITE_FCM_MESSAGING_SENDER_ID=123456789012
VITE_FCM_APP_ID=1:123456789012:web:abcdef123456
# VAPID key — Firebase console > Project settings > Cloud Messaging > Web push certificates
VITE_FCM_VAPID_KEY=your-vapid-key-here
