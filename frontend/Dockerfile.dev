# Development only — Vite dev server with HMR (hot module reload)
# File changes on your machine reflect instantly in the browser

FROM node:18-alpine

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm install

COPY . .

EXPOSE 5173

# --host 0.0.0.0 makes Vite accessible outside the container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
