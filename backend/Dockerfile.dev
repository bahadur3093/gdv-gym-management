# Development only — uses nodemon for hot reload
# Your local ./backend folder is mounted in, so changes reflect instantly

FROM node:18-alpine

WORKDIR /app
COPY package.json package-lock.json ./

# Install ALL deps including devDependencies (nodemon lives here)
RUN npm install

COPY . .

EXPOSE 4000

# nodemon watches for file changes and restarts automatically
CMD ["npm", "run", "dev"]
